#3D surface : 

def plot_tes_jes_surface(
    tes_grid,
    jes_grid,
    nll_grid
):

    from mpl_toolkits.mplot3d import Axes3D
    import matplotlib.pyplot as plt

    fig = plt.figure(figsize=(8,6))

    ax = fig.add_subplot(
        111,
        projection="3d"
    )

    ax.plot_surface(
        tes_grid,
        jes_grid,
        nll_grid
    )

    ax.set_xlabel("TES")
    ax.set_ylabel("JES")
    ax.set_zlabel("Delta NLL")

    ax.set_title(
        "Systematic likelihood surface"
    )

    plt.show()


def plot_confidence_contours(
    tes_grid,
    jes_grid,
    delta_nll
):

    import matplotlib.pyplot as plt

    plt.figure(figsize=(7,6))

    plt.contour(
        tes_grid,
        jes_grid,
        delta_nll,
        levels=[1.15, 3.0],
    )

    plt.xlabel("TES")
    plt.ylabel("JES")

    plt.title(
        "Confidence contours"
    )

    plt.grid()

    plt.show()
